{
  "name": "playwright-e2e-salesforce",
  "version": "1.0.0",
  "description": "Playwright TypeScript test automation framework for Salesforce Products page",
  "private": true,
  "scripts": {
    "test": "playwright test",
    "test:smoke": "playwright test --grep @smoke",
    "test:regression": "playwright test --grep @regression",
    "test:headed": "playwright test --headed",
    "test:ui": "playwright test --ui",
    "test:report": "playwright show-report",
    "lint": "eslint . --ext .ts"
  },
  "devDependencies": {
    "playwright": "^1.54.2",
    "@types/node": "^22.15.0",
    "eslint": "^9.25.1",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.31.0"
  }
}
